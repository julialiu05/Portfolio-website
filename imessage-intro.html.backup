                <div class="mbp-display">
                  <div class="display-edge">
                    <div class="bezel">
                      <div class="display-camera"></div>
                      <div class="display-frame">
                        <!-- Screen content goes here -->
                        <div class="mbp-screen-content">
                          <div class="p1-preview-container">
                            <!-- Ambient effects layers -->
                            <div class="p1-aurora"></div>
                            <div class="p1-color-shift"></div>
                            <div class="p1-glow-orbs">
                              <div class="p1-glow-orb"></div>
                              <div class="p1-glow-orb"></div>
                              <div class="p1-glow-orb"></div>
                            </div>
                            <div class="p1-particles">
                              <div class="p1-particle"></div>
                              <div class="p1-particle"></div>
                              <div class="p1-particle"></div>
                              <div class="p1-particle"></div>
                              <div class="p1-particle"></div>
                            </div>
                            <div class="p1-breathe"></div>

                            <!-- Nodes network overlay (appears after click) -->
                            <div class="p1-nodes-container">
                              <!-- Camera view - pans up to follow the animation -->
                              <div class="p1-camera-view">
                                <!-- Refined navigation arrow pointing UP -->
                                <div class="p1-nav-arrow">
                                  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <!-- Outer glow circle -->
                                    <circle cx="12" cy="12" r="11" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.3)" stroke-width="0.5"/>
                                    <!-- Inner arrow - clean chevron style -->
                                    <path d="M12 6L6 14h4v4h4v-4h4L12 6z" fill="#fff"/>
                                  </svg>
                                </div>
                                <!-- Extending line going up -->
                                <div class="p1-extend-line"></div>
                                <!-- Destination node with emoji -->
                                <div class="p1-dest-node">🚀</div>
                                <!-- Let's debate text with mini cursor -->
                                <div class="p1-debate-text">
                                  <svg class="p1-debate-cursor" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M5.5 3.21V20.8c0 .45.54.67.85.35l4.86-4.86a.5.5 0 0 1 .35-.15h6.87c.48 0 .72-.58.38-.92L6.35 2.85a.5.5 0 0 0-.85.36Z" fill="#fff" stroke="#000" stroke-width="1"/>
                                  </svg>
                                  <span class="p1-debate-typed">let's debate</span>
                                </div>
                              </div>
                            </div>

